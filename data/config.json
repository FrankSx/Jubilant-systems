{
  "version": "1.0.0-13thHour",
  "suite_name": "Adversarial ML Testing Suite",

  "generation": {
    "default_count": 100,
    "max_count": 100000,
    "attack_probability": 0.7,
    "available_attacks": [
      "homoglyph",
      "invisible",
      "zwj",
      "rtl",
      "case",
      "leet",
      "glitch",
      "punycode",
      "emoji"
    ]
  },

  "testing": {
    "timeout_seconds": 30,
    "max_retries": 3,
    "batch_size": 100,
    "parallel_workers": 4
  },

  "validation": {
    "pii_patterns_enabled": true,
    "injection_detection_enabled": true,
    "encoding_validation_enabled": true,
    "prompt_leakage_detection_enabled": true,
    "consistency_check_enabled": true
  },

  "fuzzing": {
    "default_iterations": 10000,
    "max_duration_seconds": 3600,
    "mutation_strategies": [
      "bit_flip",
      "byte_insertion",
      "unicode",
      "format_string",
      "length",
      "grammar"
    ],
    "seed_corpus_size": 100
  },

  "reporting": {
    "formats": ["html", "json", "markdown"],
    "include_visualizations": true,
    "max_findings_in_report": 100
  },

  "safety": {
    "max_content_length": 10000,
    "forbidden_patterns": [
      "<script",
      "javascript:",
      "onerror=",
      "onload=",
      "eval(",
      "document.cookie"
    ],
    "allowed_encodings": ["utf-8", "ascii", "latin-1"]
  }
}
